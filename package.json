{
  "name": "logi30",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "client": "npm --prefix client run dev",
    "server": "npm --prefix server run dev",
    "dev": "concurrently --names \"API,CLIENT\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" \"npm run server\" \"npm run client\"",
    "install:client": "npm --prefix client install",
    "install:server": "npm --prefix server install",
    "install:all": "npm install && npm run install:server && npm -run install:client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iwasaki-hub/Logi30.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/iwasaki-hub/Logi30/issues"
  },
  "homepage": "https://github.com/iwasaki-hub/Logi30#readme",
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
